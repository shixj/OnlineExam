.bank-card {
  transition: transform 0.2s ease;
}

.home-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.home-action-card {
  box-sizing: border-box;
  min-height: 176rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e4edf8;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.06);
}

.home-action-card--history {
  border-color: #dbeafe;
  background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
}

.home-action-card--logout {
  border-color: #fee2e2;
  background: linear-gradient(135deg, #fff8f8 0%, #fff1f2 100%);
}

.home-action-card__eyebrow {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
}

.home-action-card__title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #0f172a;
}

.home-action-card--logout .home-action-card__title {
  color: #b91c1c;
}

.home-action-card__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #64748b;
}
