.history-row:first-child {
  margin-top: 12rpx;
}

.history-row--clickable {
  position: relative;
  padding-right: 16rpx;
}

.history-row--clickable::after {
  content: ">";
  position: absolute;
  right: 0;
  top: 24rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.history-clear-button {
  background: #fff1f2;
  color: #be123c;
  box-shadow: inset 0 0 0 2rpx rgba(190, 24, 93, 0.12);
  border: none;
  font-weight: 700;
}
